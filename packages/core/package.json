{
  "name": "@tell/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "typecheck": "tsc --noEmit",
    "capture:fixture": "tsx src/scripts/capture-fixture.ts",
    "diagnose:fixture": "tsx src/scripts/diagnose-fixture.ts"
  },
  "dependencies": {
    "@tell/schema": "workspace:*",
    "playwright": "^1.49.1",
    "zod": "^3.24.1",
    "@tell/redesign": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
