# Taste engine (Gemini)
GEMINI_API_KEY=your-gemini-api-key

# Cursor-backed redesign drafts (optional; deterministic fallback works without it)
CURSOR_API_KEY=
CURSOR_MODEL=composer-2.5
CURSOR_AGENT_TIMEOUT_MS=75000

# Reserved for richer source-aware diffs (optional)
ANTHROPIC_API_KEY=

# Fixture URLs for local demo
TELL_FIXTURE_URL=http://localhost:3001
TELL_REPORT_ARTIFACT=fixtures/reports/tell-report.json

# Deployment (production)
TELL_DISABLE_REPO_SETUP=1
TELL_REPO_SETUP_TOKEN=
TELL_REPO_ROOT=
TELL_CAPTURE_TIMEOUT_MS=60000

# Hybrid: Vercel UI → capture backend (set on Vercel after backend deploy)
# Example: https://tell-capture.onrender.com
TELL_CAPTURE_API_URL=

# Vercel Blob — durable share links for /api/reports/share (auto-created on Vercel when Blob store is linked)
BLOB_READ_WRITE_TOKEN=

# GitHub Actions — repo variable for PR preview diagnosis (Settings → Secrets and variables → Actions → Variables)
# Set TELL_PREVIEW_URL to your stable Vercel production URL, e.g. https://tell-five.vercel.app
TELL_PREVIEW_URL=

# ── Grafana Cloud observability (optional) ────────────────────────────────────
# Get these from: Grafana Cloud → Connections → Add new connection → OpenTelemetry
# Traces land in Tempo; use Grafana Explore or grafana-assistant CLI to query them.
#
#   grafana-assistant prompt "Show me p95 latency for tell.diagnose spans in the last hour"
#   grafana-assistant prompt "Find any tell.diagnose spans where tell.live=false today"
#   grafana-assistant prompt "Are there errors in tell.redesign spans in the last 30 minutes?"
#
OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-<region>.grafana.net/otlp
# Header format: Authorization=Basic <base64(grafana-instance-id:grafana-api-token)>
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <your-base64-token>
OTEL_SERVICE_NAME=tell
