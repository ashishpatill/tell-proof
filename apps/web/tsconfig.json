{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "noEmit": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"],
      "@tell/schema": ["../../packages/schema/src"],
      "@tell/taste": ["../../packages/taste/src"],
      "@tell/redesign": ["../../packages/redesign/src"],
      "@tell/core": ["../../packages/core/src"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
