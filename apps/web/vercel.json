{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd ../.. && pnpm install",
  "buildCommand": "cd ../.. && pnpm -F @tell/web build",
  "framework": "nextjs",
  "env": {
    "TELL_DISABLE_REPO_SETUP": "1"
  },
  "functions": {
    "src/app/api/diagnose/route.ts": {
      "maxDuration": 90
    },
    "src/app/api/redesign/route.ts": {
      "maxDuration": 90
    },
    "src/app/api/proof/apply/route.ts": {
      "maxDuration": 180
    }
  }
}
